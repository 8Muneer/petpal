{
  "name": "functions",
  "description": "Cloud Functions for PetPal",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "test:rules": "cd .. && firebase emulators:exec --only firestore,auth \"node functions/test/firestore-rules.test.mjs\"",
    "test:storage": "cd .. && firebase emulators:exec --only storage \"node functions/test/storage-rules.test.mjs\"",
    "test:functions": "cd .. && firebase emulators:exec --only firestore,auth \"node functions/test/cloud-functions.test.js\"",
    "test": "npm run test:rules && npm run test:storage && npm run test:functions"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
