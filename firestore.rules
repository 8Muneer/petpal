rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true when the requesting user has role == 'admin' in their
    // /users/{uid} document. Used to gate all POI write operations.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // The booking's effective end date: endDate for sitting bookings, requestedDate
    // for walk bookings. Walk bookings store `endDate: null` explicitly (the key is
    // present), so `.get('endDate', fallback)` would return that literal null instead
    // of falling back — this ternary checks the value itself, not just key presence.
    function bookingEffectiveDate(data) {
      return data.get('endDate', null) != null
        ? data.get('endDate', null)
        : data.get('requestedDate', null);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      // role is restricted to non-privileged values on every create path —
      // including the isMock seeding path — so a user can't self-assign admin
      // at signup, and admin can only ever be granted via the setUserRole
      // Cloud Function, which writes with the Admin SDK and bypasses these
      // rules entirely.
      allow create: if request.auth != null &&
        (request.auth.uid == userId || request.resource.data.isMock == true) &&
        request.resource.data.role in ['petOwner', 'serviceProvider'];
      // Rating aggregates (ratingAverage/reviewCount) are written exclusively by the
      // onReviewWrite Cloud Function (Admin SDK bypasses these rules) — no client
      // branch allows writing those fields, so a review can't be forged by any
      // authenticated user patching another provider's rating directly.
      // Admins may edit any other user's document (status, verification)
      // for moderation — but role/userType stays off-limits even for admins here,
      // since role changes must go through setUserRole (audited, last-admin-safe).
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isAdmin()) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'userType', 'ratingAverage', 'reviewCount']);
      allow delete: if request.auth != null && (request.auth.uid == userId || resource.data.isMock == true);

      match /pets/{petId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          request.auth.uid == userId ||
          request.resource.data.isMock == true ||
          (resource != null && resource.data.isMock == true)
        );
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && (
        request.resource.data.authorUid == request.auth.uid ||
        request.resource.data.isMock == true
      );
      allow update: if request.auth != null && (
        // Author can edit their own post (content, images, etc.)
        request.auth.uid == resource.data.authorUid ||
        // Any authenticated user may like/unlike or increment commentCount —
        // guard by asserting the immutable fields are untouched.
        (
          request.resource.data.authorUid == resource.data.authorUid &&
          request.resource.data.content == resource.data.content &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.createdAt == resource.data.createdAt
        )
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.authorUid ||
        resource.data.isMock == true
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.authorUid ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorUid == request.auth.uid
        );
      }
    }

    match /walk_requests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.ownerUid || resource.data.isMock == true);
    }

    match /sitting_requests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.ownerUid || resource.data.isMock == true);
    }

    match /walk_services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null && (request.resource.data.providerUid == request.auth.uid || request.resource.data.isMock == true);
      // rating/reviewCount are written exclusively by the onReviewWrite Cloud
      // Function (Admin SDK bypasses these rules) — the owning provider can edit
      // every other field on their own listing, but not self-inflate their rating.
      allow update: if request.auth != null &&
        resource.data.providerUid == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'reviewCount']);
      allow delete: if request.auth != null && (resource.data.providerUid == request.auth.uid || resource.data.isMock == true);
    }

    match /sitting_services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null && (request.resource.data.providerUid == request.auth.uid || request.resource.data.isMock == true);
      // rating/reviewCount are written exclusively by the onReviewWrite Cloud
      // Function (Admin SDK bypasses these rules) — the owning provider can edit
      // every other field on their own listing, but not self-inflate their rating.
      allow update: if request.auth != null &&
        resource.data.providerUid == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'reviewCount']);
      allow delete: if request.auth != null && (resource.data.providerUid == request.auth.uid || resource.data.isMock == true);
    }

    match /lost_found_posts/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.reporterUid == request.auth.uid;
      allow update: if request.auth != null &&
        // reporterUid is always immutable
        request.resource.data.reporterUid == resource.data.reporterUid &&
        // Only the reporter can update their own post from the client
        resource.data.reporterUid == request.auth.uid &&
        // matches and matchingStatus are written exclusively by Cloud Functions
        // (Admin SDK bypasses these rules — server writes are always allowed)
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['matches', 'matchingStatus']);
      allow delete: if request.auth != null && resource.data.reporterUid == request.auth.uid;
    }

    // ── service_requests ─────────────────────────────────────────────────────
    match /service_requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true ||
        resource.data.ownerUid == request.auth.uid ||
        resource.data.targetProviderUid == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;

      // ── applications sub-collection ──────────────────────────────────────
      match /applications/{applicationId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/service_requests/$(requestId)).data.ownerUid == request.auth.uid ||
          resource.data.providerUid == request.auth.uid
        );
        allow create: if request.auth != null &&
          request.resource.data.providerUid == request.auth.uid;
        allow update: if request.auth != null &&
          get(/databases/$(database)/documents/service_requests/$(requestId)).data.ownerUid == request.auth.uid;
        allow delete: if false;
      }
    }

    // ── collection-group rule for applications (required for collectionGroup queries) ──
    match /{path=**}/applications/{applicationId} {
      allow read: if request.auth != null &&
        resource.data.providerUid == request.auth.uid;
    }

    // ── collection-group rule for pets (required for collectionGroup queries) ──
    match /{path=**}/pets/{petId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.isMock == true
      );
    }

    // ── booking_requests ─────────────────────────────────────────────────────
    match /booking_requests/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.providerUid == request.auth.uid ||
        resource.data.isMock == true
      );
      allow create: if request.auth != null && (
        (request.resource.data.ownerUid == request.auth.uid &&
         request.resource.data.providerUid != request.auth.uid &&
         request.resource.data.status == 'pending' &&
         // For sitting bookings, endDate must not precede startDate
         (request.resource.data.get('startDate', null) == null ||
          request.resource.data.get('endDate', null) == null ||
          request.resource.data.endDate >= request.resource.data.startDate)) ||
        request.resource.data.isMock == true
      );
      allow update: if request.auth != null &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.providerUid == resource.data.providerUid &&
        (
          // Owner cancels a pending, accepted, or awaiting-confirmation booking
          (request.auth.uid == resource.data.ownerUid &&
           request.resource.data.status == 'cancelled' &&
           request.resource.data.cancelledBy == 'owner' &&
           (resource.data.status == 'pending' || resource.data.status == 'accepted' || resource.data.status == 'awaitingConfirmation') &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledBy'])) ||
          // Provider cancels a booking they already accepted
          (request.auth.uid == resource.data.providerUid &&
           request.resource.data.status == 'cancelled' &&
           request.resource.data.cancelledBy == 'provider' &&
           resource.data.status == 'accepted' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledBy'])) ||
          // Provider accepts or declines a pending booking
          (request.auth.uid == resource.data.providerUid &&
           (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined') &&
           resource.data.status == 'pending' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'providerNote'])) ||
          // Provider requests completion of an accepted booking (two-sided confirm),
          // only on/after the service end date (or when no date was set)
          (request.auth.uid == resource.data.providerUid &&
           request.resource.data.status == 'awaitingConfirmation' &&
           resource.data.status == 'accepted' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
           (bookingEffectiveDate(resource.data) == null ||
            request.time >= bookingEffectiveDate(resource.data))) ||
          // Owner confirms the service was completed
          (request.auth.uid == resource.data.ownerUid &&
           request.resource.data.status == 'completed' &&
           resource.data.status == 'awaitingConfirmation' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
          // Owner marks an accepted booking complete directly (closes the
          // "provider never requests completion" gap), only on/after the
          // service end date (or when no date was set)
          (request.auth.uid == resource.data.ownerUid &&
           request.resource.data.status == 'completed' &&
           resource.data.status == 'accepted' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
           (bookingEffectiveDate(resource.data) == null ||
            request.time >= bookingEffectiveDate(resource.data))) ||
          // Owner disputes completion: booking returns to accepted
          (request.auth.uid == resource.data.ownerUid &&
           request.resource.data.status == 'accepted' &&
           resource.data.status == 'awaitingConfirmation' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        );
      allow delete: if request.auth != null && resource.data.isMock == true;
    }

    // ── reviews ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (reviewId == request.resource.data.bookingId &&
         request.resource.data.reviewerUid == request.auth.uid &&
         request.resource.data.rating >= 1 &&
         request.resource.data.rating <= 5 &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.ownerUid == request.auth.uid &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.providerUid == request.resource.data.providerId &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.status == 'completed') ||
        request.resource.data.isMock == true
      );
      allow update: if request.auth != null &&
        resource.data.reviewerUid == request.auth.uid &&
        request.resource.data.reviewerUid == resource.data.reviewerUid &&
        request.resource.data.providerId == resource.data.providerId &&
        request.resource.data.bookingId == resource.data.bookingId &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow delete: if request.auth != null && resource.data.isMock == true;
    }

    // ── admin_audit ──────────────────────────────────────────────────────────
    // Written exclusively by the setUserRole Cloud Function (Admin SDK bypasses
    // these rules) — no client branch allows writing here, so the audit trail
    // can't be forged or cleared by an admin covering their own tracks.
    match /admin_audit/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── verification_requests ────────────────────────────────────────────────
    // Restored: this collection had no rule at all (default-deny), which was
    // silently blocking AdminRepository.getAdminStats()/watchPendingVerifications()
    // for every admin, not just non-admins.
    match /verification_requests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && (
        isAdmin() || resource.data.userId == request.auth.uid
      );
      allow delete: if false;
    }

    // ── reports (content moderation) ─────────────────────────────────────────
    // Restored: same default-deny gap as verification_requests above — was
    // blocking the moderation queue and admin dashboard's open-reports count
    // for admins.
    match /reports/{reportId} {
      allow create: if request.auth != null && (
        request.resource.data.reporterId == request.auth.uid ||
        request.resource.data.isMock == true
      );
      allow read: if request.auth != null && isAdmin();
      // Reports are written with a deterministic id (type_targetId_reporterId)
      // so a resubmission on the same target overwrites instead of creating a
      // duplicate document — that overwrite is a Firestore *update*, not a
      // create, so the original reporter needs update access to their own
      // report (re-flagging settled content re-opens it as 'open' again).
      // They can't repoint the doc at a different target/type/reporter.
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.reporterId == request.auth.uid &&
         request.resource.data.reporterId == request.auth.uid &&
         request.resource.data.targetId == resource.data.targetId &&
         request.resource.data.type == resource.data.type) ||
        // Re-seeding overwrites a prior mock report at the same deterministic
        // id — allowed only mock-to-mock, so a real report can't be hijacked
        // by a "mock" rewrite and a mock report can't be laundered into real.
        (resource.data.isMock == true && request.resource.data.isMock == true)
      );
      allow delete: if false;
    }

    // ── notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Every booking/review notification is written server-side by a Cloud
      // Function (Admin SDK, which bypasses these rules). The ONLY notification a
      // client legitimately writes is the 'newMessage' one for the other chat
      // participant (the sender can't trigger a function for this) — so the
      // client create path is scoped to exactly that: type must be 'newMessage',
      // it must start unread, the requester must be a participant of the named
      // conversation, and the recipient (userId) must be the *other* participant.
      // This removes the previous "any signed-in user can forge any notification
      // into anyone's feed" hole without affecting the server-written types.
      allow create: if request.auth != null &&
        request.resource.data.type == 'newMessage' &&
        request.resource.data.isRead == false &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participants &&
        request.resource.data.userId in get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participants &&
        request.resource.data.userId != request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── pois ─────────────────────────────────────────────────────────────────
    match /pois/{poiId} {
      allow read:   if request.auth != null;
      allow create: if isAdmin() || (request.auth != null && request.resource.data.isMock == true);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (request.auth != null && resource.data.isMock == true);
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      // Participants can update the conversation's live state (last-message
      // preview, photo cache, unread counts) but cannot rewrite who the
      // conversation belongs to or touch any other field — without this,
      // a participant could silently swap the other party out of the thread.
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants &&
        request.resource.data.participants == resource.data.participants &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessage', 'lastMessageAt', 'participantPhotoUrls', 'unreadCounts']);

      match /messages/{messageId} {
        // Only a participant of the parent conversation may read its messages
        // or post into it — the previous rule only checked "is signed in,"
        // which let any authenticated user read or write into any
        // conversation by ID. `senderId` must match the real caller so a
        // message can't be forged as coming from someone else.
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
