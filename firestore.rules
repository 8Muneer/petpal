rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || request.resource.data.isMock == true);
      // Rating aggregates (ratingAverage/reviewCount) are written exclusively by the
      // onReviewWrite Cloud Function (Admin SDK bypasses these rules) — no client
      // branch allows writing those fields, so a review can't be forged by any
      // authenticated user patching another provider's rating directly.
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ratingAverage', 'reviewCount']);
      allow delete: if request.auth != null && (request.auth.uid == userId || resource.data.isMock == true);

      match /pets/{petId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          request.auth.uid == userId ||
          request.resource.data.isMock == true ||
          (resource != null && resource.data.isMock == true)
        );
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null && (
        // Author can edit their own post (content, images, etc.)
        request.auth.uid == resource.data.authorUid ||
        // Any authenticated user may like/unlike or increment commentCount —
        // guard by asserting the immutable fields are untouched.
        (
          request.resource.data.authorUid == resource.data.authorUid &&
          request.resource.data.content == resource.data.content &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.createdAt == resource.data.createdAt
        )
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorUid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.authorUid ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorUid == request.auth.uid
        );
      }
    }

    match /walk_requests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.ownerUid || resource.data.isMock == true);
    }

    match /sitting_requests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.ownerUid || resource.data.isMock == true);
    }

    match /walk_services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null && (request.resource.data.providerUid == request.auth.uid || request.resource.data.isMock == true);
      // rating/reviewCount are written exclusively by the onReviewWrite Cloud
      // Function (Admin SDK bypasses these rules) — the owning provider can edit
      // every other field on their own listing, but not self-inflate their rating.
      allow update: if request.auth != null &&
        resource.data.providerUid == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'reviewCount']);
      allow delete: if request.auth != null && (resource.data.providerUid == request.auth.uid || resource.data.isMock == true);
    }

    match /sitting_services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null && (request.resource.data.providerUid == request.auth.uid || request.resource.data.isMock == true);
      // rating/reviewCount are written exclusively by the onReviewWrite Cloud
      // Function (Admin SDK bypasses these rules) — the owning provider can edit
      // every other field on their own listing, but not self-inflate their rating.
      allow update: if request.auth != null &&
        resource.data.providerUid == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rating', 'reviewCount']);
      allow delete: if request.auth != null && (resource.data.providerUid == request.auth.uid || resource.data.isMock == true);
    }

    match /lost_found_posts/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.reporterUid == request.auth.uid;
      allow update: if request.auth != null &&
        // reporterUid is always immutable
        request.resource.data.reporterUid == resource.data.reporterUid &&
        // Only the reporter can update their own post from the client
        resource.data.reporterUid == request.auth.uid &&
        // matches and matchingStatus are written exclusively by Cloud Functions
        // (Admin SDK bypasses these rules — server writes are always allowed)
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['matches', 'matchingStatus']);
      allow delete: if request.auth != null && resource.data.reporterUid == request.auth.uid;
    }

    // ── service_requests ─────────────────────────────────────────────────────
    match /service_requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true ||
        resource.data.ownerUid == request.auth.uid ||
        resource.data.targetProviderUid == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid;

      // ── applications sub-collection ──────────────────────────────────────
      match /applications/{applicationId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/service_requests/$(requestId)).data.ownerUid == request.auth.uid ||
          resource.data.providerUid == request.auth.uid
        );
        allow create: if request.auth != null &&
          request.resource.data.providerUid == request.auth.uid;
        allow update: if request.auth != null &&
          get(/databases/$(database)/documents/service_requests/$(requestId)).data.ownerUid == request.auth.uid;
        allow delete: if false;
      }
    }

    // ── collection-group rule for applications (required for collectionGroup queries) ──
    match /{path=**}/applications/{applicationId} {
      allow read: if request.auth != null &&
        resource.data.providerUid == request.auth.uid;
    }

    // ── collection-group rule for pets (required for collectionGroup queries) ──
    match /{path=**}/pets/{petId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.isMock == true
      );
    }

    // ── booking_requests ─────────────────────────────────────────────────────
    match /booking_requests/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.providerUid == request.auth.uid ||
        resource.data.isMock == true
      );
      allow create: if request.auth != null && (
        (request.resource.data.ownerUid == request.auth.uid &&
         request.resource.data.providerUid != request.auth.uid &&
         request.resource.data.status == 'pending') ||
        request.resource.data.isMock == true
      );
      allow update: if request.auth != null &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.providerUid == resource.data.providerUid &&
        (
          // Owner cancels a pending or accepted booking
          (request.auth.uid == resource.data.ownerUid &&
           request.resource.data.status == 'cancelled' &&
           (resource.data.status == 'pending' || resource.data.status == 'accepted') &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
          // Provider accepts or declines a pending booking
          (request.auth.uid == resource.data.providerUid &&
           (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined') &&
           resource.data.status == 'pending' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'providerNote']))
        );
      allow delete: if request.auth != null && resource.data.isMock == true;
    }

    // ── reviews ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (reviewId == request.resource.data.bookingId &&
         request.resource.data.reviewerUid == request.auth.uid &&
         request.resource.data.rating >= 1 &&
         request.resource.data.rating <= 5 &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.ownerUid == request.auth.uid &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.providerUid == request.resource.data.providerId &&
         get(/databases/$(database)/documents/booking_requests/$(reviewId)).data.status == 'accepted') ||
        request.resource.data.isMock == true
      );
      allow update: if request.auth != null &&
        resource.data.reviewerUid == request.auth.uid &&
        request.resource.data.reviewerUid == resource.data.reviewerUid &&
        request.resource.data.providerId == resource.data.providerId &&
        request.resource.data.bookingId == resource.data.bookingId &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow delete: if request.auth != null && resource.data.isMock == true;
    }

    // ── notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null; // client-side writes from app actions
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── pois ─────────────────────────────────────────────────────────────────
    match /pois/{poiId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.isMock == true;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.isMock == true;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
