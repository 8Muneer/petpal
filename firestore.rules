rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isParticipant(convId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── Walk requests ──────────────────────────────────────────────────────────
    match /walk_requests/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // ── Sitting requests ───────────────────────────────────────────────────────
    match /sitting_requests/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // ── Conversations ──────────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read, update: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;

      // ── Messages ─────────────────────────────────────────────────────────────
      match /messages/{msgId} {
        // Any participant can read and create messages
        allow read, create: if isParticipant(convId);
        // Only the sender can delete their own message
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
