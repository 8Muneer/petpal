rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Uploads must be images and reasonably sized. `request.resource` is null
    // on delete, so deletes pass through this check unchanged — the cap only
    // constrains create/update. 10MB comfortably covers the app's pickers,
    // which already compress to imageQuality 75-85.
    function isValidImage() {
      return request.resource == null ||
        (request.resource.size < 10 * 1024 * 1024 &&
         request.resource.contentType.matches('image/.*'));
    }

    // Profile images — only the owner can write; any signed-in user can read
    match /profile_images/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && isValidImage();
    }

    // Pet images — scoped to the owning user
    match /pets/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && isValidImage();
    }

    // Walk service images — any authenticated provider can write
    match /walk_services/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isValidImage();
    }

    // Sitting service images
    match /sitting_services/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isValidImage();
    }

    // Lost & Found images — publicly readable; scoped per user so no one can
    // overwrite another user's photo (M4 fix).
    match /lost_found/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId && isValidImage();
    }

    // Feed / community post images
    match /post_images/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isValidImage();
    }

    // POI images — uploaded by the admin POI editor.
    // Storage rules can't run a Firestore get() the way isAdmin() does in
    // firestore.rules, so this checks a custom auth-token claim instead.
    // The claim is set by the setUserRole Cloud Function whenever a user's
    // role is set to/from 'admin' (functions/index.js) — never trust the
    // client's own routing as the enforcement layer for a write rule.
    match /poi_images/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'admin' && isValidImage();
    }
  }
}
