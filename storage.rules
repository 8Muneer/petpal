rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images — only the owner can write; any signed-in user can read
    match /profile_images/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Pet images — scoped to the owning user
    match /pets/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Walk service images — any authenticated provider can write
    match /walk_services/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Sitting service images
    match /sitting_services/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Lost & Found images — publicly readable; any signed-in user can post
    match /lost_found/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Feed / community post images
    match /post_images/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
